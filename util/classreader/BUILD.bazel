load("//feature/configurator:feature.bzl", "feature")

feature(
    type = "library",
)

load("@rules_java//java:defs.bzl", "java_library")

java_library(
    name = "classreader",
    srcs = glob(["src/main/java/**/*.java"]),
    resources = glob(["src/main/resources/**"], allow_empty = True,),
    visibility = ["//visibility:public"],
    javacopts = ["-source", "21", "-target", "21"],
    deps = ["//util/common:common",
        "//util/collection:collection"],
)