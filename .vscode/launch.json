{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bazel Run",
      "type": "shell",
      "command": "bazel run //dein/package:target",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Bazel Run (Debug)",
      "type": "shell",
      "command": "bazel run //dein/package:target -- --jvm_flags='-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=5005'",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Listening for transport dt_socket.*"
        }
      }
    }
  ],
  "configurations": [
    {
      "type": "java",
      "name": "Attach to Bazel",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005,
      "timeout": 30000,
